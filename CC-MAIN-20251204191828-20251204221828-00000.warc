    if ($(window).scrollTop() >= 100) {
      $('.feedback-banner').addClass('fixed-header');
      $('footer').removeClass('logged-footer');
    } else {
      $('.feedback-banner').removeClass('fixed-header');
      $('footer').addClass('logged-footer');
    }
  });
  $(document).ready(function() {
    if ($(window).scrollTop() >= 100) {
      $('.feedback-banner').addClass('fixed-header');
    }
  });

</script>
