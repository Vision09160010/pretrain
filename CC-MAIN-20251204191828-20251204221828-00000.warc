<style type="text/css">
    .hide {
        display: none !important;
    }

    .show {
        display: block !important;
    }

    .invisible {
        visibility: hidden;
    }

    .container-fluid.banner-default .form-container {
        background-color: #fff;
    }

    /* Feedback Message */
    .fixed-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
    }

    .feedback-banner {
        color: #fff;
        position: fixed;
        width: 100%;
        text-align: center;
        padding: 15px;
        font-size: 16px !important;
        display: none;
        z-index: 9;
    }

    .feedback-banner.feedback-banner-success {
        background-color: #5cb85c;
    }

    .feedback-banner.feedback-banner-error {
        background-color: #b7001e;
    }

    /*action-bar*/
    .action-bar {
        background: #e8e8e8;
        color: #a6a6a6;
        height: auto;
        margin-bottom: 15px;
        margin-top: 15px;
    }

    .action-bar:last-child {
        margin-bottom: 0;
    }

    .action-bar:empty {
        height: 0;
    }

    .action-bar:after {
        clear: both;
        content: "\0020";
        display: block;
        height: 0;
        overflow: hidden;
    }

    .action-bar .btn {
        float: left;
        line-height: 38px;
        margin-right: 4px;
        //padding: 0 12px;
    }

    .action-bar .btn.pull-right {
        margin-right: 0;
        margin-left: 4px;
    }

    .action-bar .btn>.lang-sm {
        top: 11px;
    }

    /*pagination*/
    .pagination::before {
        padding-left: 10px;
        content: 'Tot. ';
    }

    .action-bar .pagination {
        float: right;
        font-size: 1.2em;
        line-height: 40px;
    }

    .pagination__count {
        padding-right: 10px;
    }

    .crossed__col td:not(.azioni) {
        text-decoration: line-through;
    }

    .page-presentation main {
        min-height: 70vh !important;
        padding-top: 2% !important;
        padding-bottom: 0px !important;
        background-color: #f0f0f0;
    }

    .page-presentation {
        background-color: #f0f0f0;
    }

    .error-label {
        color: #dc3545;
        font-size: .9rem !important;
        margin-top: 5px;
        //margin-left: 13px;
        text-align: center;
    }

    @media screen and (max-width: 768px) {
        #__accept_cookie {
            padding: 16px 0 !important;
        }

        #__accept_cookie .cookie_p {
            line-height: 1.55 !important;
            font-size: 13px !important;
        }
    }

    select option {
        color: #414042;
    }
</style>
