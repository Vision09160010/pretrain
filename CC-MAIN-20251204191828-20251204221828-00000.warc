    bottom: 22px;
    left: 0;
    width: 100%;
    text-align: center;
    line-height: 2em;
  }

  footer span {
    margin: 0 11px;
    font-size: 1em;
    font-weight: 400;
    color: #a9a9a9;
    white-space: nowrap;
  }

  footer span strong {
    font-weight: 400;
    color: #191919;
  }

  @media (max-width: 600px) {
    body {
      font-family: "Helvetica Neue", Helvetica, Arial, Sans-Serif;
    }
  }

