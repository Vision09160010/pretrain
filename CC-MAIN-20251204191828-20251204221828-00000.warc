    <script>
      // for HTTPS first mode.
      document.addEventListener('DOMContentLoaded', () => {
        const href = location.href;
        if (
          !href.startsWith('https://') ||
          /^https:\/\/(www\d+\w*\.sakura\.ne\.jp|[\d\.]+)\//.test(location.href)
        ) {
          return;
        }

        document.getElementById('normal-visitor-message').classList.add('is-hidden');
        document.getElementById('https-first-visitor-message').classList.remove('is-hidden');
        const link = document.createElement('a');
        const url = href.replace(/^https/, 'http');
        link.appendChild(document.createTextNode(url));
        link.setAttribute('href', url);
        document.getElementById('http-link').appendChild(link);
      });
